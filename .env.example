# Refer 2.0 - Environment Variables Configuration
# Copy this file to .env and fill in the values

# --- DATABASE ---
DATABASE_URL=postgres://user:password@host:port/dbname

# --- FIREBASE & GCP ---
# Service Account credentials for Firebase Admin SDK
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_CLIENT_EMAIL=firebase-service-account@your-project-id.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
FIREBASE_STORAGE_BUCKET=your-project-id.appspot.com

# Specific for Vertex AI & System Monitoring
GOOGLE_CLOUD_PROJECT=your-project-id
GOOGLE_CLOUD_LOCATION=us-central1
GOOGLE_CLOUD_REGION=us-central1

# --- ARTIFICIAL INTELLIGENCE ---
# Standard Google AI SDK
GEMINI_API_KEY=your-gemini-api-key

# OpenAI for Lead Matching & Insights
OPENAI_API_KEY=your-openai-api-key

# --- PAYMENTS (STRIPE) ---
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
APP_BASE_URL=https://your-app-domain.com

# --- AUTOMATION (n8n) ---
N8N_API_KEY=your-n8n-api-key
N8N_WEBHOOK_URL=https://n8n.yourdomain.com/webhook
INTERNAL_API_KEY=your-shared-internal-secret-for-incoming-requests
INTERNAL_WEBHOOK_SECRET=your-shared-secret-for-webhooks

# --- TELECOM (AFRICA'S TALKING) ---
AT_USERNAME=sandbox
AT_API_KEY=your-africas-talking-api-key
AT_SENDER_ID=REFER
AT_USSD_CODE=*384*123#

# --- SERVER ---
PORT=5000
NODE_ENV=development
